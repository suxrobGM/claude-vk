{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.configPath": "./prettier.config.js",
  "editor.formatOnSave": true,
  "files.exclude": {
    "node_modules": true,
    "**/*/node_modules": true,
    "**/*/dist": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "VSCodeCounter.exclude": ["bun.lock"]
}
