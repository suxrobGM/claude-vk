{
  "name": "@claude-vk/server",
  "private": true,
  "type": "module",
  "main": "src/app.ts",
  "scripts": {
    "start": "bun run src/app.ts",
    "dev": "bun run --watch src/app.ts",
    "build": "bun build src/app.ts --target=bun --outfile=../dist/server.js --external pino-pretty --define process.env.NODE_ENV='\"production\"'",
    "test": "bun test",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.0",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.28",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "vk-io": "^4.10.1",
    "zod": "^4.4.3"
  }
}
