# claude-vk — VK channel plugin configuration
#
# Real file location: ~/.claude/channels/vk/.env
#
# Shell environment ALWAYS wins on conflict: `VK_TOKEN=... claude ...`
# overrides whatever is in this file.

# === Required ===

# Community access token from vk.com → Manage → API usage → Access tokens.
# Required scopes: messages, photos, docs, manage.
VK_TOKEN=

# === Callback API (webhook) ===
#
# The plugin only supports the Callback API. Front 127.0.0.1:6060 with your own
# reverse proxy (Caddy, Cloudflare Tunnel, ngrok) and point VK's "Callback API"
# settings at it.

# Shared secret VK sends with every callback delivery. Recommended.
VK_WEBHOOK_SECRET=

# String VK expects back from the `confirmation` event (set in VK admin).
VK_WEBHOOK_CONFIRMATION=

# === HTTP listener ===

VK_PORT=6060
VK_HTTP_BIND=127.0.0.1

# === Diagnostics ===

# trace | debug | info | warn | error
LOG_LEVEL=info

# development enables pino-pretty colored logs on stderr.
# NODE_ENV=development
