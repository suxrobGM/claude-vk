# claude-vk — VK channel plugin configuration
#
# Real file location: ~/.claude/channels/vk/.env
# Override location: set VK_STATE_DIR env var before launching Claude Code.
#
# Shell environment ALWAYS wins on conflict: `VK_TOKEN=... claude ...`
# overrides whatever is in this file. Edits to .env are hot-reloaded — no
# need to restart Claude Code when you change VK_COMMUNITY_ID or similar.

# === Required (from M1 onward) ===

# Community access token from vk.com → Manage → API usage → Access tokens.
# Required scopes: messages, photos, docs, manage.
VK_TOKEN=

# Numeric community ID (e.g. 123456789). Find it in vk.com → Manage.
VK_COMMUNITY_ID=

# Community short-name without the leading @ (e.g. "my_assistant"). Used to
# resolve @mention detection in group chats.
VK_COMMUNITY_SCREEN_NAME=

# === Transport (M2 / M6) ===

# longpoll (default, recommended) or callback (webhook receiver on :6060).
# Callback mode requires a public reverse proxy fronting 127.0.0.1:6060.
VK_TRANSPORT=longpoll

# Shared secret VK sends with every callback delivery. Required for callback
# mode; ignored for longpoll.
VK_WEBHOOK_SECRET=

# === HTTP listener ===

VK_PORT=6060
VK_HTTP_BIND=127.0.0.1

# === Optional ===

# en | ru — language of bot auto-replies (pairing codes, error messages).
VK_LOCALE=en

# Enable remote tool-approval relay over VK DM (M7). Off by default.
VK_PERMISSION_RELAY=false

# Override the state directory. Use to run multiple instances on one machine.
# VK_STATE_DIR=

# === Diagnostics ===

# trace | debug | info | warn | error
LOG_LEVEL=info

# development enables pino-pretty colored logs on stderr.
# NODE_ENV=development
